{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Go HTML Template",
  "scopeName": "text.html.gotemplate",
  "fileTypes": ["gohtml"],
  "patterns": [
    { "include": "#go-template" },
    { "include": "text.html.basic" }
  ],
  "repository": {
    "go-template": {
      "patterns": [
        { "include": "#go-template-comment" },
        { "include": "#go-template-action" }
      ]
    },
    "go-template-comment": {
      "name": "comment.block.go-template",
      "begin": "\\{\\{-?/\\*",
      "end": "\\*/[\\s\\t]*-?\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.go-template" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.go-template" }
      }
    },
    "go-template-action": {
      "begin": "\\{\\{-?",
      "end": "-?\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.go-template" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.go-template" }
      },
      "contentName": "source.go.embedded.go-template",
      "patterns": [
        { "include": "#go-template-keywords" },
        { "include": "#go-template-variable" },
        { "include": "#go-template-field" },
        { "include": "#go-template-string-double" },
        { "include": "#go-template-string-backtick" },
        { "include": "#go-template-number" },
        { "include": "#go-template-operator" }
      ]
    },
    "go-template-keywords": {
      "match": "\\b(if|else|end|range|with|block|define|template|return|nil|true|false)\\b",
      "name": "keyword.control.go-template"
    },
    "go-template-variable": {
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.go-template"
    },
    "go-template-field": {
      "patterns": [
        {
          "match": "\\.[A-Z][a-zA-Z0-9_]*",
          "name": "variable.other.property.go-template"
        },
        {
          "match": "\\.[a-z][a-zA-Z0-9_]*",
          "name": "variable.other.property.go-template"
        },
        {
          "match": "\\.$",
          "name": "variable.language.dot.go-template"
        },
        {
          "match": "\\.",
          "name": "variable.language.dot.go-template"
        }
      ]
    },
    "go-template-string-double": {
      "name": "string.quoted.double.go-template",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.go-template",
          "match": "\\\\."
        }
      ]
    },
    "go-template-string-backtick": {
      "name": "string.quoted.backtick.go-template",
      "begin": "`",
      "end": "`"
    },
    "go-template-number": {
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "name": "constant.numeric.go-template"
    },
    "go-template-operator": {
      "match": ":=|\\||\\||&&|!|==|!=|<=|>=|<|>",
      "name": "keyword.operator.go-template"
    }
  }
}
